# ─── AI Provider ───────────────────────────────────────────────────────────────
# Choose: "openrouter" (default, paid) or "google" (free tier)
AI_PROVIDER=openrouter

# ─── OpenRouter (paid) ─────────────────────────────────────────────────────────
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Google AI Studio (free) ──────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-key-here

# ─── Model selection ───────────────────────────────────────────────────────────
# For OpenRouter:
AI_MODEL=openai/gpt-5.4-pro

# For Google AI Studio (used by run_free.py):
# AI_MODEL=gemini-2.5-flash

# Alternative: Gemini 3 Pro via Google AI Studio (routed through OpenRouter)
# AI_MODEL=google/gemini-3-pro

# Browse all available models: https://openrouter.ai/models
